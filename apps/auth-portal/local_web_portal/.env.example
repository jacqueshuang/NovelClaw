# Auth Portal 本地 Web 示例。复制到 apps/auth-portal/local_web_portal/.env 后使用。

# 访问与入口
# [建议填写] APP_BASE_URL：当前入口页对外访问地址。代码当前会读取该值，便于后续统一入口域名配置。
APP_BASE_URL=http://127.0.0.1:8010
# [建议保留默认] APP_MULTIAGENT_URL：MultiAgent 工作台入口地址，通常指向 8011 的 dashboard。
APP_MULTIAGENT_URL=http://127.0.0.1:8011/dashboard
# [建议保留默认] APP_CLAW_URL：NovelClaw 工作台入口地址，通常指向 8012 的 dashboard。
APP_CLAW_URL=http://127.0.0.1:8012/dashboard
# [建议保留默认] WEB_UI_LANGUAGE：默认界面语言，可选 zh 或 en；示例值默认中文。
WEB_UI_LANGUAGE=zh

# 会话与安全
# [建议填写] APP_SESSION_COOKIE_NAME：浏览器中的会话 Cookie 名称；示例值适合当前共享入口。
APP_SESSION_COOKIE_NAME=colong_shared_session
# [可选] APP_SESSION_COOKIE_DOMAIN：只有在需要跨子域共享 Cookie 时再填写，本地开发可留空。
APP_SESSION_COOKIE_DOMAIN=
# [必填] APP_SESSION_SECRET：会话签名密钥。本地预览模式下程序可自动生成，但生产环境必须显式设置。
APP_SESSION_SECRET=
# [建议保留默认] APP_HTTPS_ONLY：是否仅通过 HTTPS 发送 Cookie。0 适合本地开发，1 适合 HTTPS 反向代理后的部署。
APP_HTTPS_ONLY=0

# 数据与预览
# [可选] APP_DATABASE_URL：Auth Portal 数据库地址。留空时默认使用 local_web_portal/data/app.db。
APP_DATABASE_URL=
# [建议保留默认] APP_PREVIEW_USER_EMAIL：预览模式默认使用的本地会话邮箱。
APP_PREVIEW_USER_EMAIL=preview@novelclaw.local
