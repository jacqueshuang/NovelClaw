# MultiAgent 部署环境变量模板。复制到 /etc/novelclaw/multiagent.env 后按实际部署修改。

# 路由与共享会话
# [建议保留默认] APP_HTTPS_ONLY：部署在 HTTPS 反向代理后建议保持 1，使会话 Cookie 仅通过 HTTPS 发送。
APP_HTTPS_ONLY=1
# [建议保留默认] APP_BASE_PATH：当前服务挂载到反向代理的路径前缀；需与 Nginx 中的 /multiagent 保持一致。
APP_BASE_PATH=/multiagent
# [建议保留默认] APP_SESSION_COOKIE_NAME：浏览器中的共享会话 Cookie 名称；需与 Auth Portal、NovelClaw 保持一致。
APP_SESSION_COOKIE_NAME=colong_shared_session
# [可选] APP_SESSION_COOKIE_DOMAIN：只有需要跨子域共享登录态时再填写，例如 .example.com；单域名部署可留空。
APP_SESSION_COOKIE_DOMAIN=
# [必填] APP_SESSION_SECRET：会话签名密钥。生产环境必须显式设置。
APP_SESSION_SECRET=
# [必填] APP_ENCRYPTION_KEY：用于加密保存 Provider 密钥。生产环境必须显式设置。
APP_ENCRYPTION_KEY=

# 数据目录与跨服务连接
# [可选] APP_DATABASE_URL：MultiAgent 自身数据库地址。留空时默认回退到 local_web_portal/data/app.db。
APP_DATABASE_URL=
# [建议填写] APP_AUTH_DATABASE_URL：Auth Portal 数据库地址；共享登录态与用户资料时需要填写。
APP_AUTH_DATABASE_URL=
# [可选] APP_SHARED_PORTAL_URL：共享入口的对外地址；填写后工作台内返回 Portal 的链接会指向该地址。
APP_SHARED_PORTAL_URL=
# [可选] APP_RUNS_DIR：任务运行记录目录。留空时默认回退到 apps/multiagent/runs。
APP_RUNS_DIR=

# 运行控制
# [建议保留默认] WEB_BUILTIN_PROVIDERS：默认启用的内置 Provider 列表。
WEB_BUILTIN_PROVIDERS=deepseek
# [建议保留默认] WEB_DEFAULT_PROVIDER：默认选中的模型提供方。
WEB_DEFAULT_PROVIDER=deepseek
# [建议保留默认] WEB_MAX_ITERATIONS：单次任务最大迭代轮数；值越大，运行时间通常越长。
WEB_MAX_ITERATIONS=8
# [建议保留默认] WEB_MAX_TOTAL_ITERATIONS：任务允许的总迭代上限，用于限制整体成本。
WEB_MAX_TOTAL_ITERATIONS=16
# [建议保留默认] WEB_JOB_TIMEOUT_SECONDS：任务总超时秒数；0 表示不额外限制。
WEB_JOB_TIMEOUT_SECONDS=0
# [建议保留默认] WEB_JOB_IDLE_TIMEOUT_SECONDS：任务空闲超时秒数；0 表示不额外限制。
WEB_JOB_IDLE_TIMEOUT_SECONDS=0
# [建议保留默认] WEB_STARTUP_RECOVERY_SECONDS：服务重启后，超过这个秒数未恢复心跳的旧任务会被回收。
WEB_STARTUP_RECOVERY_SECONDS=180
# [建议保留默认] WEB_STALE_QUEUED_SECONDS：排队超过该秒数的旧任务会被恢复流程清理。
WEB_STALE_QUEUED_SECONDS=180
# [建议保留默认] WEB_FAST_MODE：1 为更快的生成流程，0 为更完整但更慢的流程。
WEB_FAST_MODE=1
# [建议保留默认] WEB_FULL_CYCLE_INTERVAL：每隔多少轮执行一次完整周期检查。
WEB_FULL_CYCLE_INTERVAL=3
# [建议保留默认] WEB_CHAPTERS_PER_ITER：每轮生成的章节数。
WEB_CHAPTERS_PER_ITER=1
# [建议保留默认] WEB_MAX_CHAPTER_SUBROUNDS：单章节的最大子轮次。
WEB_MAX_CHAPTER_SUBROUNDS=2
# [建议保留默认] WEB_EVAL_INTERVAL：评估步骤的执行间隔轮次。
WEB_EVAL_INTERVAL=8

# 模型调用与检索开关
# [建议保留默认] LLM_TIMEOUT_SECONDS：对外模型请求的超时秒数；0 表示使用默认行为。
LLM_TIMEOUT_SECONDS=0
# [建议保留默认] LLM_MAX_RETRIES：模型请求失败后的最大重试次数。
LLM_MAX_RETRIES=1
# [建议保留默认] WEB_MEMORY_ONLY_MODE：1 表示仅使用动态记忆链路；0 表示继续按下方开关组合启用检索能力。
WEB_MEMORY_ONLY_MODE=0
# [建议保留默认] WEB_ENABLE_RAG：1 表示启用知识检索增强流程。
WEB_ENABLE_RAG=1
# [建议保留默认] WEB_ENABLE_STATIC_KB：1 表示启用静态知识库检索；当前模板默认关闭。
WEB_ENABLE_STATIC_KB=0
# [建议保留默认] WEB_ENABLE_EVALUATOR：1 表示启用额外评估步骤。
WEB_ENABLE_EVALUATOR=1
# [可选] VECTOR_DB_PATH：向量库根目录。留空时默认回退到 ./vector_db。
VECTOR_DB_PATH=

# Python 与模型缓存
# [建议保留默认] PYTHONUTF8：1 表示强制 Python 使用 UTF-8 输出。
PYTHONUTF8=1
# [建议保留默认] PYTHONIOENCODING：标准输入输出编码，建议保持 utf-8。
PYTHONIOENCODING=utf-8
# [建议保留默认] HF_HUB_OFFLINE：1 表示禁止 Hugging Face Hub 联网；仅在完全离线部署时开启。
HF_HUB_OFFLINE=0
# [建议保留默认] TRANSFORMERS_OFFLINE：1 表示 transformers 仅使用本地缓存，不再联网拉取模型。
TRANSFORMERS_OFFLINE=0
# [可选] HF_HOME：Hugging Face 缓存目录；需要自定义缓存位置时再填写。
HF_HOME=
# [建议保留默认] EMBEDDING_MODEL：向量模型名称；`none` 表示关闭该能力。
EMBEDDING_MODEL=none
# [建议保留默认] DISABLE_EMBEDDING_DOWNLOADS：1 表示禁止自动下载向量模型依赖。
DISABLE_EMBEDDING_DOWNLOADS=1
